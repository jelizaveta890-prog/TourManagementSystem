@model TourManagementSystem.Models.Tour

@{
    ViewData["Title"] = "Details";
    // Kasutame CultureInfo.CurrentCulture, mis on seotud meie Program.cs seadistusega
    var culture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
}

<style>
    body {
        background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(15px);
        border-radius: 25px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        padding: 40px;
        width: 100%;
        max-width: 650px;
        margin: 40px auto;
    }

    .detail-row {
        padding: 15px 0;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .detail-label {
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: #7f8c8d;
        letter-spacing: 1px;
    }

    .detail-value {
        font-size: 1.1rem;
        color: #2c3e50;
    }

    .btn-edit {
        background: linear-gradient(45deg, #f1c40f, #f39c12);
        border: none;
        border-radius: 50px;
        padding: 10px 30px;
        font-weight: bold;
        color: white;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(243, 156, 18, 0.4);
            color: white;
        }

    .back-link {
        color: #3498db;
        text-decoration: none;
        font-weight: 500;
        margin-left: 15px;
    }

    .price-badge {
        background: #27ae60;
        color: white;
        padding: 5px 15px;
        border-radius: 10px;
        font-weight: bold;
    }
</style>

<div class="container">
    <div class="glass-card shadow">
        <div class="text-center mb-4">
            <h2 class="fw-bold">
                @if (culture == "ru")
                {
                    <text>Детали тура</text>
                }
                else if (culture == "et")
                {

                    <text>Reisi üksikasjad</text>
                }
                else
                {

                    <text>Tour Details</text>
                }
            </h2>
            <hr>
        </div>

        <div class="detail-row row">
            <div class="col-sm-4 detail-label">@(culture == "et" ? "Reisi nimi" : culture == "ru" ? "Название" : "Tour Name")</div>
            <div class="col-sm-8 detail-value fw-bold">@Html.DisplayFor(model => model.Name)</div>
        </div>

        <div class="detail-row row">
            <div class="col-sm-4 detail-label">@(culture == "et" ? "Sihtkoht" : culture == "ru" ? "Место назначения" : "Destination")</div>
            <div class="col-sm-8 detail-value">📍 @Html.DisplayFor(model => model.Destination)</div>
        </div>

        <div class="detail-row row">
            <div class="col-sm-4 detail-label">@(culture == "et" ? "Hind" : culture == "ru" ? "Цена" : "Price")</div>
            <div class="col-sm-8 detail-value">
                <span class="price-badge">@Html.DisplayFor(model => model.Price) €</span>
            </div>
        </div>

        <div class="detail-row row">
            <div class="col-sm-4 detail-label">@(culture == "et" ? "Kirjeldus" : culture == "ru" ? "Описание" : "Description")</div>
            <div class="col-sm-8 detail-value text-muted">@Html.DisplayFor(model => model.Description)</div>
        </div>

        <div class="mt-5 text-center">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit shadow-sm">
                @(culture == "et" ? "Muuda" : culture == "ru" ? "Изменить" : "Edit")
            </a>
            <a asp-action="Index" class="back-link">
                @(culture == "et" ? "Tagasi nimekirja" : culture == "ru" ? "Назад к списку" : "Back to List")
            </a>
        </div>
    </div>
</div>