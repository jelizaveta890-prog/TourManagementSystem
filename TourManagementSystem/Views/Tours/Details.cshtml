@model TourManagementSystem.Models.Tour

@{
    ViewData["Title"] = "Tour Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 border p-4 shadow-sm bg-white rounded">
            <h2>Tour Details</h2>
            <hr />

            <dl class="row">
                <dt class="col-sm-3 text-muted">Tour Name:</dt>
                <dd class="col-sm-9 fw-bold">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3 text-muted">Destination:</dt>
                <dd class="col-sm-9"> @Html.DisplayFor(model => model.Destination)</dd>

                <dt class="col-sm-3 text-muted">Price:</dt>
                <dd class="col-sm-9 text-success fw-bold">@Html.DisplayFor(model => model.Price) €</dd>

                <dt class="col-sm-3 text-muted">Description:</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>
            </dl>

            <div class="mt-4 border-top pt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Details</a>
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </div>
    </div>
</div>