@model TourManagementSystem.Models.Tour

@{
    ViewData["Title"] = "Edit";

    // 1. Loeme keele otse küpsisest
    var cookieName = Microsoft.AspNetCore.Localization.CookieRequestCultureProvider.DefaultCookieName;
    var cookieValue = Context.Request.Cookies[cookieName];

    // 2. Määrame vaikekeeleks inglise keele
    string culture = "en";

    // 3. Kui küpsis on olemas, siis võtame sealt keele lühendi (nt "c=et|uic=et")
    if (!string.IsNullOrEmpty(cookieValue))
    {
        if (cookieValue.Contains("et")) culture = "et";
        else if (cookieValue.Contains("ru")) culture = "ru";
    }
}

@* DEBUG: See rida näitab meile nüüd raudkindlalt, mis keele kood leidis *@
<div class="alert alert-info py-1 text-center" style="font-size: 0.8rem;">
    Silur: Küpsise sisu: @cookieValue | Tuvastatud keel: <strong>@culture</strong>
</div>

<style>
    body {
        /* Kasutame sama stiilset taustapilti, mis pealehel */
        background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(15px);
        border-radius: 25px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        padding: 40px;
        width: 100%;
        max-width: 550px;
        margin: 40px auto;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid rgba(0,0,0,0.1);
        padding: 12px;
        background: rgba(255, 255, 255, 0.9);
        transition: 0.3s;
    }

        .form-control:focus {
            border-color: #00c6ff;
            box-shadow: 0 0 0 4px rgba(0, 198, 255, 0.2);
        }

    label {
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 8px;
        margin-top: 15px;
        display: block;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-save {
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        border: none;
        border-radius: 50px;
        padding: 14px;
        font-weight: bold;
        color: white;
        width: 100%;
        margin-top: 30px;
        transition: 0.3s;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 114, 255, 0.3);
            color: white;
        }

    .back-link {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: #7f8c8d;
        text-decoration: none;
        font-weight: 500;
        transition: 0.3s;
    }

        .back-link:hover {
            color: #2c3e50;
        }
</style>

<div class="container">
    <div class="glass-card shadow">
        <div class="text-center mb-4">
            <h2 class="fw-bold">
                @if (culture == "ru")
                {
                    <text>Редактировать тур</text>
                }
                else if (culture == "et")
                {

                    <text>Muuda reisi seadeid</text>
                }
                else
                {

                    <text>Edit Tour Settings</text>
                }
            </h2>
            <p class="text-muted small">ID: @Model.Id</p>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label>@(culture == "et" ? "Reisi nimi" : culture == "ru" ? "Название" : "Tour Name")</label>
                <input asp-for="Name" class="form-control" placeholder="..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label>@(culture == "et" ? "Sihtkoht" : culture == "ru" ? "Место назначения" : "Destination")</label>
                <input asp-for="Destination" class="form-control" placeholder="..." />
                <span asp-validation-for="Destination" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label>@(culture == "et" ? "Hind (€)" : culture == "ru" ? "Цена" : "Price")</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label>@(culture == "et" ? "Kirjeldus" : culture == "ru" ? "Описание" : "Description")</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-save shadow-sm">
                @if (culture == "ru")
                {
                    <text>Сохранить изменения</text>
                }
                else if (culture == "et")
                {

                    <text>Salvesta muudatused</text>
                }
                else
                {

                    <text>Save Changes</text>
                }
            </button>
        </form>

        <a asp-action="Index" class="back-link">
            @(culture == "et" ? "← Tagasi nimekirja" : culture == "ru" ? "← Назад к списку" : "← Back to List")
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}