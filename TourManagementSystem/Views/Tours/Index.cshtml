@{
    ViewData["Title"] = "Welcome to Travel Agency";
}

<style>
    .welcome-hero {
        background: linear-gradient(135deg, #1D9E75 0%, #0F6E56 100%);
        color: white;
        border-radius: 20px;
        padding: 60px 40px;
        text-align: center;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(29, 158, 117, 0.2);
    }

    .welcome-title {
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .welcome-sub {
        font-size: 18px;
        opacity: 0.9;
        margin-bottom: 24px;
    }

    .btn-explore {
        background: white;
        color: #0F6E56;
        font-weight: 600;
        padding: 12px 30px;
        border-radius: 12px;
        text-decoration: none;
        display: inline-block;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .btn-explore:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.15);
            color: #0F6E56;
        }

    .section-title {
        font-size: 24px;
        font-weight: 600;
        color: #111;
        margin-bottom: 20px;
        text-align: center;
    }

    /* Используем ту же сетку карточек, что и в каталоге */
    .promo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .promo-card {
        background: white;
        border: 1px solid #eee;
        border-radius: 16px;
        overflow: hidden;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }

        .promo-card:hover {
            transform: translateY(-4px);
            border-color: #9FE1CB;
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }

    .promo-thumb {
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        border-bottom: 1px solid #eee;
    }

    /* Разные фоны для красивого разнообразия карточек */
    .thumb-paris {
        background: #E3F2FD;
    }

    .thumb-bali {
        background: #E8F5E9;
    }

    .thumb-rome {
        background: #FFF3E0;
    }

    .promo-body {
        padding: 20px;
    }

    .promo-name {
        font-size: 18px;
        font-weight: 600;
        color: #111;
        margin-bottom: 4px;
    }

    .promo-dest {
        font-size: 13px;
        color: #777;
        margin-bottom: 10px;
    }

    .promo-desc {
        font-size: 13px;
        color: #555;
        line-height: 1.5;
        margin-bottom: 20px;
        height: 60px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .promo-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid #f5f5f5;
        padding-top: 15px;
    }

    .promo-price {
        font-size: 20px;
        font-weight: 700;
        color: #1D9E75;
    }

    .btn-book {
        background: #1D9E75;
        color: white;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s;
    }

        .btn-book:hover {
            background: #0F6E56;
            color: white;
        }
</style>

<div class="container mt-4">
    <div class="welcome-hero">
        <h1 class="welcome-title">Find Your Next Adventure</h1>
        <p class="welcome-sub">Discover amazing places at exclusive prices with Travel Agency</p>
        <a asp-controller="Tours" asp-action="Index" class="btn-explore">Explore All Tours ➔</a>
    </div>

    <h2 class="section-title">🔥 Popular Destinations</h2>

    <div class="promo-grid">
        <div class="promo-card">
            <div class="promo-thumb thumb-paris">🗼</div>
            <div class="promo-body">
                <div class="promo-name">Romantic Weekend in Paris</div>
                <div class="promo-dest">📍 France, Europe</div>
                <p class="promo-desc">Enjoy the view from the Eiffel Tower, walk along the Seine, and taste fresh croissants in cozy local cafes.</p>
                <div class="promo-footer">
                    <div class="promo-price">€ 499</div>
                    <a asp-controller="Tours" asp-action="Index" class="btn-book">Details</a>
                </div>
            </div>
        </div>

        <div class="promo-card">
            <div class="promo-thumb thumb-bali">🏝️</div>
            <div class="promo-body">
                <div class="promo-name">Bali Exotic Getaway</div>
                <div class="promo-dest">📍 Indonesia, Asia</div>
                <p class="promo-desc">Relax on pristine beaches, explore ancient jungle temples, and experience world-class surfing and spa retreats.</p>
                <div class="promo-footer">
                    <div class="promo-price">€ 1,250</div>
                    <a asp-controller="Tours" asp-action="Index" class="btn-book">Details</a>
                </div>
            </div>
        </div>

        <div class="promo-card">
            <div class="promo-thumb thumb-rome">🏛️</div>
            <div class="promo-body">
                <div class="promo-name">Ancient Wonders of Rome</div>
                <div class="promo-dest">📍 Italy, Europe</div>
                <p class="promo-desc">Step back in history visiting the majestic Colosseum, the Vatican, and don't forget to make a wish at Trevi Fountain!</p>
                <div class="promo-footer">
                    <div class="promo-price">€ 399</div>
                    <a asp-controller="Tours" asp-action="Index" class="btn-book">Details</a>
                </div>
            </div>
        </div>
    </div>
</div>