<div class="wrap">

    <!-- Hero header -->
    <div class="hero">
        <div>
            <div class="hero-eyebrow">Tour catalog</div>
            <div class="hero-title">All Tours</div>
            <div class="hero-sub">Manage and explore your travel offerings</div>
        </div>
        <a asp-action="Create" class="btn-add">+ Add New Tour</a>
    </div>

    <!-- Stats -->
    <div class="stats">
        <div class="stat">
            <div class="stat-icon">🗺️</div>
            <div class="stat-num">@Model.Count()</div>
            <div class="stat-label">Total tours</div>
        </div>
        <div class="stat">
            <div class="stat-icon">📍</div>
            <div class="stat-num">@Model.Select(t => t.Destination).Distinct().Count()</div>
            <div class="stat-label">Destinations</div>
        </div>
        <div class="stat">
            <div class="stat-icon">💶</div>
            <div class="stat-num">€ @(Model.Any() ? Model.Min(t => t.Price).ToString() : "—")</div>
            <div class="stat-label">Starting from</div>
        </div>
    </div>

    <!-- Section title -->
    <div class="section-header">
        <div class="section-title">
            Tours <span class="badge-count">@Model.Count() total</span>
        </div>
    </div>

    <!-- Empty state -->
    @if (!Model.Any())
    {
        <div class="empty">
            <div class="empty-icon">✈️</div>
            <div>No tours yet. <a asp-action="Create">Add your first one!</a></div>
        </div>
    }
    else
    {
        <!-- Cards grid -->
        <div class="tours-grid">
            @foreach (var tour in Model)
            {
                <div class="tour-card">
                    <div class="card-thumb">✈️</div>
                    <div class="card-body">
                        <div class="card-name">@tour.Name</div>
                        <div class="card-dest">📍 @tour.Destination</div>
                        <div class="card-footer">
                            <div class="price">€ @tour.Price</div>
                            <div class="actions">
                                <a asp-action="Details" asp-route-id="@tour.Id" class="act view" title="View">👁</a>
                                <a asp-action="Edit" asp-route-id="@tour.Id" class="act edit" title="Edit">✏️</a>
                                <a asp-action="Delete" asp-route-id="@tour.Id" class="act del" title="Delete">🗑</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
