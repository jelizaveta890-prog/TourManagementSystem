@model IEnumerable<TourManagementSystem.Models.Tour>

@{
    ViewData["Title"] = "Tours Catalog - Travel Agency";
}

<style>
    /* Premium Catalog Dashboard Styling */
    .catalog-header {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 20px;
        padding: 24px 32px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
        margin-bottom: 30px;
    }

    .catalog-tag {
        color: #1D9E75;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.08em;
        display: inline-block;
        margin-bottom: 4px;
    }

    .catalog-title {
        font-size: 28px;
        font-weight: 800;
        color: #111;
        margin-bottom: 4px;
    }

    .catalog-subtitle {
        font-size: 14px;
        color: #666;
        margin-bottom: 0;
    }

    .btn-add-tour {
        background: #1D9E75;
        color: white;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        transition: background 0.2s ease, transform 0.2s ease;
    }

        .btn-add-tour:hover {
            background: #0F6E56;
            color: white;
            transform: translateY(-1px);
        }

    /* Live C# Dashboard Stats */
    .stat-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.01);
        height: 100%;
    }

    .stat-label {
        font-size: 13px;
        color: #777;
        font-weight: 500;
        margin-bottom: 6px;
    }

    .stat-value {
        font-size: 26px;
        font-weight: 800;
        color: #111;
    }

        .stat-value.price-color {
            color: #1D9E75;
        }

    /* Modern Responsive Grid Layout */
    .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
        gap: 24px;
        margin-bottom: 50px;
    }

    .catalog-card {
        background: white;
        border: 1px solid #eaeaea;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

        .catalog-card:hover {
            transform: translateY(-4px);
            border-color: #9FE1CB;
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
        }

    .catalog-thumb {
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 50px;
        background: #F4FBF9;
        border-bottom: 1px solid #eaeaea;
    }

    .catalog-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .catalog-name {
        font-size: 19px;
        font-weight: 700;
        color: #111;
        margin-bottom: 6px;
    }

    .catalog-meta {
        font-size: 13px;
        color: #666;
        margin-bottom: 12px;
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .rating-badge {
        background: #FFF9E6;
        color: #F5A623;
        padding: 1px 6px;
        border-radius: 4px;
        font-weight: 700;
    }

    .catalog-desc {
        font-size: 13px;
        color: #555;
        line-height: 1.6;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 62px;
    }

    .catalog-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid #f5f5f5;
        padding-top: 16px;
        margin-top: auto;
    }

    .catalog-price {
        font-size: 20px;
        font-weight: 800;
        color: #1D9E75;
    }

    /* Management Control Buttons */
    .action-group {
        display: flex;
        gap: 6px;
    }

    .btn-action {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-action-view {
        background: #E8F5E9;
        color: #0F6E56;
    }

        .btn-action-view:hover {
            background: #1D9E75;
            color: white;
        }

    .btn-action-edit {
        background: #FFF3E0;
        color: #E65100;
    }

        .btn-action-edit:hover {
            background: #FFB74D;
            color: white;
        }

    .btn-action-delete {
        background: #FFEBEE;
        color: #C62828;
    }

        .btn-action-delete:hover {
            background: #E57373;
            color: white;
        }
</style>

<div class="container mt-4">
    <div class="catalog-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <span class="catalog-tag">Exploration Hub</span>
            <h1 class="catalog-title">Tours Catalog</h1>
            <p class="catalog-subtitle">Manage, edit, and explore all available global destinations</p>
        </div>
        <div>
            <a asp-action="Create" class="btn-add-tour">+ Add New Tour</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-label">🗺️ Total Active Tours</div>
                <div class="stat-value">@Model.Count()</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-label">📍 Unique Destinations</div>
                <div class="stat-value">@Model.Select(t => t.Destination).Distinct().Count()</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-label">💶 Lowest Starting Price</div>
                <div class="stat-value price-color">
                    @(Model.Any() ? $"€ {Model.Min(t => t.Price)}" : "—")
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white border rounded-3 shadow-sm">
            <div style="font-size: 60px; margin-bottom: 15px;">✈️</div>
            <h3 class="fw-bold">No Tours Found</h3>
            <p class="text-muted mb-3">Your database is currently empty or connections are initializing.</p>
            <a asp-action="Create" class="btn btn-success btn-sm px-4 py-2 fw-bold">Create First Tour</a>
        </div>
    }
    else
    {
        <div class="catalog-grid">
            @foreach (var tour in Model)
            {
                <div class="catalog-card">
                    <div class="catalog-thumb">@(string.IsNullOrEmpty(tour.Emoji) ? "🌍" : tour.Emoji)</div>
                    <div class="catalog-body">
                        <div class="catalog-name">@tour.Name</div>
                        <div class="catalog-meta">
                            <span>📍 @tour.Destination</span>
                            @if (tour.Rating > 0)
                            {
                                <span class="rating-badge">⭐ @tour.Rating.ToString("0.0")</span>
                            }
                        </div>
                        <p class="catalog-desc">@tour.Description</p>
                        <div class="catalog-footer">
                            <div class="catalog-price">€ @tour.Price</div>
                            <div class="action-group">
                                <a asp-action="Details" asp-route-id="@tour.Id" class="btn-action btn-action-view">Details</a>
                                <a asp-action="Edit" asp-route-id="@tour.Id" class="btn-action btn-action-edit">Edit</a>
                                <a asp-action="Delete" asp-route-id="@tour.Id" class="btn-action btn-action-delete">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>