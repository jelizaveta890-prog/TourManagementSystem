@model TourManagementSystem.Models.Tour

@{
    ViewData["Title"] = "Reisi tühistamine";
}

<style>
    body {
        /* Lisame ilusa reisiteemalise taustapildi */
        background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border-radius: 25px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        padding: 40px;
        color: #2c3e50;
    }

    .tour-details-box {
        background: rgba(0, 0, 0, 0.05);
        border-radius: 15px;
        padding: 20px;
        margin: 20px 0;
    }

    .btn-remove {
        background: #e74c3c;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: bold;
        transition: 0.3s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-remove:hover {
            background: #c0392b;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
            color: white;
        }

    .btn-back {
        color: #7f8c8d;
        text-decoration: none;
        font-weight: 500;
        margin-left: 20px;
    }

        .btn-back:hover {
            color: #2c3e50;
            text-decoration: underline;
        }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-7 glass-card text-center">
            <h1 class="display-6 fw-bold">Kas soovid reisist loobuda?</h1>
            <p class="text-muted">Seiklus ootab, aga kui oled kindel, saad selle siit eemaldada.</p>

            <div class="tour-details-box text-start">
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Reis:</div>
                    <div class="col-8">@Html.DisplayFor(model => model.Name)</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Sihtkoht:</div>
                    <div class="col-8">📍 @Html.DisplayFor(model => model.Destination)</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Hind:</div>
                    <div class="col-8 text-success fw-bold">@Html.DisplayFor(model => model.Price) €</div>
                </div>
            </div>

            <div class="mt-4">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn-remove shadow">Jah, eemalda see reis</button>
                    <a asp-action="Index" class="btn-back">Ei, soovin alles jätta</a>
                </form>
            </div>
        </div>
    </div>
</div>