@model TourManagementSystem.Models.Tour

@{
    ViewData["Title"] = "Delete Tour";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 border p-4 shadow-sm bg-light rounded">
            <h2 class="text-danger">Delete Tour</h2>
            <p>Are you sure you want to delete this tour from the list?</p>
            <hr />

            <dl class="row">
                <dt class="col-sm-4">Tour Name:</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-4">Destination:</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Destination)</dd>

                <dt class="col-sm-4">Price:</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Price) €</dd>

                <dt class="col-sm-4">Description:</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Description)</dd>
            </dl>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </form>
        </div>
    </div>
</div>